<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:background="@drawable/bg_notif_card"
    android:layout_marginBottom="8dp" android:padding="14dp"
    android:clickable="true" android:focusable="true">
    <TextView android:id="@+id/tvNotifIcon"
        android:layout_width="36dp" android:layout_height="36dp"
        android:gravity="center" android:textSize="20sp" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:layout_marginStart="10dp">
        <TextView android:id="@+id/tvNotifTitle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvNotifBody"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="#88FFFFFF" android:textSize="12sp" android:layout_marginTop="2dp" />
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="✕" android:textColor="#44FFFFFF" android:textSize="14sp" android:padding="4dp" />
</LinearLayout>
