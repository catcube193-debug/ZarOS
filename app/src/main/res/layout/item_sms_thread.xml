<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="76dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingStart="16dp" android:paddingEnd="16dp"
    android:background="@drawable/bg_result_card"
    android:layout_marginStart="8dp" android:layout_marginEnd="8dp"
    android:layout_marginBottom="8dp"
    android:clickable="true" android:focusable="true">
    <TextView android:id="@+id/tvThreadInitials"
        android:layout_width="46dp" android:layout_height="46dp"
        android:gravity="center" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold"
        android:background="@drawable/bg_clock_btn_blue" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvThreadName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold" android:maxLines="1"
            android:ellipsize="end" />
        <TextView android:id="@+id/tvThreadSnippet" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#66FFFFFF"
            android:textSize="13sp" android:maxLines="1" android:ellipsize="end"
            android:layout_marginTop="3dp" />
    </LinearLayout>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end|center_vertical"
        android:layout_marginStart="8dp">
        <TextView android:id="@+id/tvThreadDate" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#44FFFFFF"
            android:textSize="11sp" android:layout_marginBottom="4dp" />
        <TextView android:id="@+id/tvThreadUnread" android:layout_width="20dp"
            android:layout_height="20dp" android:gravity="center"
            android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold"
            android:background="@drawable/bg_clock_btn_blue"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
