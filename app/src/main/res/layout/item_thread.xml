<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="72dp"
    android:orientation="horizontal" android:gravity="center_vertical"
    android:paddingStart="14dp" android:paddingEnd="14dp"
    android:clickable="true" android:focusable="true">
    <TextView android:id="@+id/tvThreadInitials"
        android:layout_width="46dp" android:layout_height="46dp"
        android:background="@drawable/bg_contact_avatar"
        android:gravity="center" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvThreadName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#FFFFFF"
            android:textSize="15sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvThreadSnippet" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#66FFFFFF"
            android:textSize="12sp" android:maxLines="1" android:ellipsize="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/tvThreadDate" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="#44FFFFFF" android:textSize="11sp" />
        <TextView android:id="@+id/tvThreadUnread" android:layout_width="20dp"
            android:layout_height="20dp" android:background="@drawable/bg_unread_badge"
            android:gravity="center" android:textColor="#FFFFFF" android:textSize="10sp"
            android:textStyle="bold" android:layout_marginTop="4dp" android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
