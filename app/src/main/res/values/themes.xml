<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ZarOS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/zar_blue_1</item>
        <item name="colorPrimaryVariant">@color/zar_blue_3</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/zar_navy</item>
        <item name="android:windowBackground">@color/zar_navy</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:soundEffectsEnabled">false</item>
        <item name="android:hapticFeedbackEnabled">false</item>
    </style>

    <style name="Widget.ZarOS.Chip" parent="Widget.MaterialComponents.Chip.Action">
        <item name="chipBackgroundColor">@color/chip_bg</item>
        <item name="android:textColor">@color/chip_text</item>
        <item name="android:textSize">12sp</item>
        <item name="chipCornerRadius">14dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="chipIconVisible">false</item>
    </style>

    <style name="SectionTitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#FF38BDF8</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:layout_marginStart">4dp</item>
    </style>

    <style name="CardGroup">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@drawable/bg_settings_card</item>
        <item name="android:clipToPadding">true</item>
    </style>

    <style name="WallOption">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:alpha">0.6</item>
    </style>


    <style name="QuickToggle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">70dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_widget_card</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:padding">4dp</item>
    </style>

    <style name="Theme.ZarOS.Transparent" parent="Theme.ZarOS">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="DialKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">64dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:backgroundTint">#FF1E293B</item>
        <item name="android:layout_margin">5dp</item>
    </style>
</resources>
<!-- This file has extra content appended - themes.xml is complete above -->
