# Local configuration — NEVER commit this. It holds your SDK path and
# real API keys (SERPER_API_KEY, GROQ_API_KEY) and must persist across
# every update untouched. This is the file that kept getting wiped when
# the project was delivered as fresh zips each time.
local.properties

# Build outputs — regenerated by Gradle every build, shouldn't be tracked
/app/build/
/build/
.gradle/

# Android Studio project metadata — machine-specific, regenerated on open
.idea/
*.iml

# OS cruft
.DS_Store
